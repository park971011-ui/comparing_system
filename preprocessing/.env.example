# 각 서비스 가입 후 발급받은 키를 복사해 .env 파일로 저장 (.env 는 git에 커밋하지 않음)

# SGIS 통계지리정보서비스 — https://sgis.kostat.go.kr/developer/html/openApi/openApiOutline.html
# Open API 신청 메뉴 > 서비스 신청 (사용자 인증키 + 비밀키 발급)
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# VWorld — https://www.vworld.kr/dev/v4dv_apidev_s001.do
# 오픈API 인증키 신청 (개인/기관 인증, 휴대폰 본인인증 필요)
VWORLD_API_KEY=

# 건축HUB (공공데이터포털 경유) — https://www.data.go.kr/data/15125733/openapi.do
# "건축물대장정보 서비스" 활용신청 (공공데이터포털 회원가입 + 활용신청 승인 대기 1~2일)
BUILDING_HUB_API_KEY=
